#!/usr/bin/env bash
## Description: Capture or update VRT baseline screenshots
## Usage: vrt-update [flags]
## Example: ddev vrt-update\nddev vrt-update --project=narrow

cd /var/www/html/.ddev/drupal-admin-vrt
npx playwright test "$@" --update-snapshots
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "To view the HTML diff report, run: ddev vrt-report"
fi
exit $EXIT_CODE

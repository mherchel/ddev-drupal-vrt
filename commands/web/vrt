#!/usr/bin/env bash
# #ddev-generated
## Description: Run visual regression tests (compare against baselines)
## Usage: vrt [flags]
## Example: ddev vrt\nddev vrt --normal\nddev vrt --full\nddev vrt --bail=10\nddev vrt --no-bail\nddev vrt --project=narrow-ltr\nddev vrt tests/vrt/all.spec.ts

cd /var/www/html/.ddev/drupal-vrt

# Resolve config-driven values from drupal-vrt.yaml.
MODES_LIST=$(node bin/read-config.mjs modes) || exit $?
DEFAULT_MODE=$(node bin/read-config.mjs default-mode) || exit $?
BAIL=$(node bin/read-config.mjs bail) || exit $?

MODE=""
PASSTHROUGH_ARGS=()
HAS_PROJECT=false

for arg in "$@"; do
  case "$arg" in
    --no-bail)
      BAIL="false"
      ;;
    --bail=*)
      BAIL="${arg#--bail=}"
      ;;
    --project=*|--project)
      HAS_PROJECT=true
      PASSTHROUGH_ARGS+=("$arg")
      ;;
    --*)
      stripped="${arg#--}"
      matched=false
      for m in $MODES_LIST; do
        if [ "$stripped" = "$m" ]; then
          MODE="$m"
          matched=true
          break
        fi
      done
      if [ "$matched" = false ]; then
        PASSTHROUGH_ARGS+=("$arg")
      fi
      ;;
    *)
      PASSTHROUGH_ARGS+=("$arg")
      ;;
  esac
done

# Prompt for a mode if none was selected and no --project was given.
if [ -z "$MODE" ] && [ "$HAS_PROJECT" = false ]; then
  echo "Select test mode:"
  i=1
  default_index=1
  for m in $MODES_LIST; do
    marker=""
    if [ "$m" = "$DEFAULT_MODE" ]; then
      marker=" (default)"
      default_index=$i
    fi
    echo "  $i) $m$marker"
    i=$((i+1))
  done
  read -r -p "Choice [$default_index]: " CHOICE
  CHOICE="${CHOICE:-$default_index}"
  i=1
  for m in $MODES_LIST; do
    if [ "$i" = "$CHOICE" ]; then
      MODE="$m"
      break
    fi
    i=$((i+1))
  done
  if [ -z "$MODE" ]; then
    echo "Invalid choice." >&2
    exit 1
  fi
fi

CMD=(npx playwright test)

# Bail-on-failures: skip the flag entirely when disabled or zero.
if [ "$BAIL" != "false" ] && [ "$BAIL" != "0" ]; then
  CMD+=(--max-failures="$BAIL")
fi

CMD+=("${PASSTHROUGH_ARGS[@]}")

VRT_MODE="$MODE" "${CMD[@]}"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "To view the HTML diff report, run: ddev vrt-report"
fi
exit $EXIT_CODE

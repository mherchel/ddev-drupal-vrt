#!/usr/bin/env bash
## Description: Run visual regression tests (compare against baselines)
## Usage: vrt [flags]
## Example: ddev vrt\nddev vrt --normal\nddev vrt --full\nddev vrt --no-bail\nddev vrt --project=narrow\nddev vrt tests/vrt/content.spec.ts

FAIL_THRESHOLD=5

# Parse our custom flags, pass the rest through to Playwright.
MODE=""
NO_BAIL=false
PASSTHROUGH_ARGS=()
for arg in "$@"; do
  case "$arg" in
    --normal)  MODE="normal" ;;
    --full)    MODE="full" ;;
    --no-bail) NO_BAIL=true ;;
    *)         PASSTHROUGH_ARGS+=("$arg") ;;
  esac
done

# If no mode flag was given and no --project flag was passed, prompt.
if [ -z "$MODE" ]; then
  HAS_PROJECT=false
  for arg in "${PASSTHROUGH_ARGS[@]}"; do
    case "$arg" in --project=*|--project) HAS_PROJECT=true ;; esac
  done

  if [ "$HAS_PROJECT" = false ]; then
    echo "Select test mode:"
    echo "  1) Normal — narrow + wide viewports, LTR only (faster)"
    echo "  2) Full   — all viewports and RTL"
    read -r -p "Choice [1]: " CHOICE
    case "$CHOICE" in
      2) MODE="full" ;;
      *) MODE="normal" ;;
    esac
  fi
fi

cd /var/www/html/.ddev/drupal-admin-vrt

# Build the Playwright command.
CMD=(npx playwright test)
if [ "$MODE" = "normal" ]; then
  CMD+=(--project=narrow --project=wide)
elif [ "$MODE" = "full" ]; then
  # Run all projects (no filter needed — Playwright runs everything by default).
  :
fi

# Stop early after N failures unless --no-bail is set.
if [ "$NO_BAIL" = false ]; then
  CMD+=(--max-failures="$FAIL_THRESHOLD")
fi

CMD+=("${PASSTHROUGH_ARGS[@]}")

"${CMD[@]}"
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "To view the HTML diff report, run: ddev vrt-report"
fi
exit $EXIT_CODE

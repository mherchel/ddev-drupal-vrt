#!/usr/bin/env bash
## Description: Run visual regression tests (compare against baselines)
## Usage: vrt [flags]
## Example: ddev vrt\nddev vrt --project=narrow\nddev vrt tests/vrt/content.spec.ts

cd /var/www/html/.ddev/drupal-admin-vrt
npx playwright test "$@"
EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "To view the HTML diff report, run: ddev vrt-report"
fi
exit $EXIT_CODE
